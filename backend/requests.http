### Variables
@baseUrl = http://localhost:3000

                                        ### POST for ROOT
### Test direct
GET http://localhost:3000/

### Test : route racine
GET {{baseUrl}}/

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "alice",
  "password": "secret123"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "alice",
  "password": "secret123"
}

### Test d'erreur : register username trop court
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "ab",
  "password": "secret123"
}

### Test d'erreur : Bad password
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "alice",
  "password": "wrong"
}

